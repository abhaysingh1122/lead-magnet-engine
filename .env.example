# Copy this file to .env and fill in your keys.
# Never commit .env to git — it's gitignored.

# Anthropic API key — required by the agent to call Claude.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Notion integration token — create one at https://www.notion.so/my-integrations
# Give the integration "Insert content" access to your target page.
NOTION_API_KEY=your_notion_api_key_here

# The Notion page ID where lead magnets will be created.
# Open your target page in Notion, copy the URL, grab the 32-char hex ID at the end.
NOTION_PARENT_PAGE_ID=your_notion_page_id_here

# Gemini API key — get one free at https://aistudio.google.com/app/apikey
# Used to generate infographics via Google Imagen 4.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Google service account credentials (for Google Drive input support)
GOOGLE_CREDENTIALS_JSON=
